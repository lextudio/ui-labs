      <Link>Upstream\DevFlowDriverJson.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\ElementInfo.cs">
      <Link>Upstream\ElementInfo.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\ScreenshotResult.cs">
      <Link>Upstream\ScreenshotResult.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\ThemeModels.cs">
      <Link>Upstream\ThemeModels.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\ExtensionModels.cs">
      <Link>Upstream\ExtensionModels.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\AlertInfo.cs">
      <Link>Upstream\AlertInfo.cs</Link>
    </Compile>
    <Compile Include="..\..\..\external\maui-labs\src\DevFlow\Microsoft.Maui.DevFlow.Driver\RecordingState.cs">
