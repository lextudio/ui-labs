<Page x:Class="UnoDevFlowTestApp.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:UnoDevFlowTestApp"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <ScrollViewer x:Name="MainScrollViewer"
                AutomationProperties.AutomationId="MainScrollViewer"
                IsTabStop="True"
                VerticalScrollMode="Enabled"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollMode="Disabled"
                HorizontalScrollBarVisibility="Disabled">
    <Grid>
      <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Spacing="16">
        <TextBlock AutomationProperties.AutomationId="HelloTextBlock"
          Text="Hello Uno Platform!"
          HorizontalAlignment="Center"
          FontSize="24"
          FontWeight="Bold" />

        <Button x:Name="ActionButton"
                AutomationProperties.AutomationId="ActionButton"
                Content="Tap Me"
                Width="180"
                Height="40"
                Click="ActionButton_Click" />

        <TextBlock x:Name="ResponseText"
                   AutomationProperties.AutomationId="ResponseText"
                   Text="Press the button or call DevFlow endpoints."
                   TextWrapping="Wrap"
                   Width="320" />

        <TextBox x:Name="EventProbeInput"
                 AutomationProperties.AutomationId="EventProbeInput"
                 Width="320"
                 Header="Event probe input"
                 GotFocus="EventProbeInput_GotFocus"
                 KeyDown="EventProbeInput_KeyDown"
                 TextChanging="EventProbeInput_TextChanging"
                 TextChanged="EventProbeInput_TextChanged" />

        <Button x:Name="EventProbeButton"
                AutomationProperties.AutomationId="EventProbeButton"
                Content="Probe Tap"
                Width="180"
                Height="40"
                Click="EventProbeButton_Click" />

        <TextBlock x:Name="EventLogText"
                   AutomationProperties.AutomationId="EventLogText"
                   Text="events:"
                   TextWrapping="Wrap"
                   Width="320" />

        <Button x:Name="DisabledActionButton"
                AutomationProperties.AutomationId="DisabledActionButton"
                Content="Disabled Tap"
                Width="180"
                Height="40"
                IsEnabled="False"
                Click="DisabledActionButton_Click" />

        <TextBlock x:Name="DisabledButtonResultText"
                   AutomationProperties.AutomationId="DisabledButtonResultText"
                   Text="disabled button untouched"
                   TextWrapping="Wrap"
                   Width="320" />

        <TextBox x:Name="DisabledInput"
                 AutomationProperties.AutomationId="DisabledInput"
                 Width="320"
                 IsEnabled="False"
                 Text="disabled input untouched"
                 Header="Disabled input" />

        <!-- Extra content to make scrolling meaningful -->
        <StackPanel Spacing="8" Width="320">
          <TextBlock Text="Scroll to see the hidden footer content" FontWeight="SemiBold" />
          <TextBlock Text="This content is intentionally long to force vertical scrolling in the sample app." TextWrapping="Wrap" />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
          <TextBlock Text="Keep scrolling..." />
        </StackPanel>

        <TextBlock x:Name="ScrollTargetText"
                   AutomationProperties.AutomationId="ScrollTargetText"
                   Text="Scroll target is here!"
                   FontWeight="Bold"
                   TextWrapping="Wrap"
                   Width="320" />
        <TextBlock Text="WebView test surface:" FontWeight="SemiBold" Width="320" />
        <Border BorderBrush="Gray" BorderThickness="1" Width="320" Height="180">
          <WebView2 x:Name="WebViewHost"
                    AutomationProperties.AutomationId="WebViewHost" />
        </Border>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
