<Window x:Class="WpfDevFlowTestApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF DevFlow Test App"
        Width="480"
        Height="320"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="WPF DevFlow Sample App" FontSize="24" FontWeight="Bold" Margin="0,0,0,12" />
            <TextBlock Text="This app is instrumented with DevFlow on port 5500." TextWrapping="Wrap" Margin="0,0,0,12" />
            <Button Name="ActionButton" Width="180" Height="40" Content="Tap Me" Click="ActionButton_Click" Margin="0,0,0,12" />
            <TextBlock Name="ResponseText" Text="Press the button or call DevFlow endpoints." TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
